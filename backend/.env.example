# ─────────────────────────────────────────────────────────────
# AI PROVIDER — pick ONE (the others can stay blank)
# ─────────────────────────────────────────────────────────────
AI_PROVIDER=gemini        # gemini | groq | openai | claude

# ── GEMINI (FREE — recommended) ──────────────────────────────
# Get free key: https://aistudio.google.com/app/apikey
# No credit card. 1,500 free requests/day.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── GROQ (FREE backup) ───────────────────────────────────────
# Get free key: https://console.groq.com
# No credit card. 14,400 free requests/day.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── OPENAI (paid but cheap) ───────────────────────────────────
# GPT-4o-mini: ~$0.15 per 1M tokens
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── CLAUDE / ANTHROPIC (paid) ────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# ─────────────────────────────────────────────────────────────
# OPTIONAL SERVICES
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NEWSAPI_KEY=

# ─────────────────────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./trading.db
SCHEDULE_INTERVAL_MIN=30
MIN_CONFIDENCE_ALERT=75
USE_FINBERT=false
